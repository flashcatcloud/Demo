#!/usr/bin/expect -f
set timeout 120
set host [lindex $argv 0]
set password [lindex $argv 1]
set source [lindex $argv 2]
set target [lindex $argv 3]

spawn scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null $source root@$host:$target
expect {
  -re "(?i)password:" {
    send "$password\r"
    exp_continue
  }
  eof
}
