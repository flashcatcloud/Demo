[Unit]
Description=Mock OTel Sample - test-gateway
After=network-online.target mock-test-insert.service mock-test-query.service
Wants=network-online.target mock-test-insert.service mock-test-query.service

[Service]
Type=simple
WorkingDirectory=/opt/mock-otel-sample/app
Environment=SERVER_PORT=8080
Environment=INSERT_URL=http://127.0.0.1:8081/api/orders
Environment=QUERY_URL=http://127.0.0.1:8082/api/orders
Environment=QUERY_HEALTH_URL=http://127.0.0.1:8082/api/health
Environment=GATEWAY_FLOW_URL=http://127.0.0.1:8080/api/gateway/flow
Environment=GATEWAY_DELAY_MS=5000
Environment=LOG_FILE=/opt/mock-otel-sample/logs/test-gateway/test-gateway.log
Environment=LOG_FILE_PATTERN=/opt/mock-otel-sample/logs/test-gateway/test-gateway.%%d{yyyy-MM-dd}.%%i.log.gz
EnvironmentFile=/etc/mock-otel-sample/otel.env
Environment=OTEL_SERVICE_NAME=test-gateway
Environment=OTEL_TRACES_EXPORTER=otlp
Environment=OTEL_METRICS_EXPORTER=otlp
Environment=OTEL_LOGS_EXPORTER=otlp
Environment=OTEL_TRACES_SAMPLER=always_on
Environment=OTEL_INSTRUMENTATION_LOGBACK_MDC_ENABLED=true
Environment=OTEL_RESOURCE_ATTRIBUTES=deployment.environment=demo,service.namespace=java-sample,service.role=request-generator
ExecStartPre=/usr/bin/grep -Eq ^OTEL_EXPORTER_OTLP_ENDPOINT=https?://[^<>[:space:]]+ /etc/mock-otel-sample/otel.env
ExecStartPre=/usr/bin/mkdir -p /opt/mock-otel-sample/logs/test-gateway
ExecStart=/usr/bin/java -javaagent:/opt/mock-otel-sample/opentelemetry-javaagent.jar -jar /opt/mock-otel-sample/app/test-gateway-0.0.1-SNAPSHOT.jar
Restart=always
RestartSec=5
SuccessExitStatus=143

[Install]
WantedBy=multi-user.target
