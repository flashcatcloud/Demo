# Path to the downloaded OpenTelemetry Java agent.
OTEL_JAVAAGENT=/opt/otel/opentelemetry-javaagent.jar

# Replace this with the collector endpoint used by the platform under test.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Keep traces, metrics, and logs enabled for acceptance testing.
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_INSTRUMENTATION_LOGBACK_MDC_ENABLED=true

# Useful resource attributes for host/service/global-view validation.
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=demo,service.namespace=java-sample

# Optional: increase trace volume in a short demo.
OTEL_TRACES_SAMPLER=always_on
